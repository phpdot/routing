{
    "name": "phpdot/routing",
    "description": "High-performance segment-trie routing for PHP. PSR-7/15/17 compliant.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["router", "routing", "trie", "psr-7", "psr-15", "http", "middleware"],
    "require": {
        "php": ">=8.3",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "nyholm/psr7": "^1.8",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Routing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
